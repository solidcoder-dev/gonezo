@startuml
skinparam componentStyle rectangle
skinparam shadowing false
hide stereotypes

actor User
actor "Mobills Export File" as MobillsFile

package "Gonezo" {
  package "Client App" {
    component UI
    database "Local Storage" as CacheDb
  }

  package "Backend" {
    component "API / Workflows" as API
    component "Mobills Import Orchestration" as MobillsImport
    component "Ledger Application" as LedgerApp
    component "Taxonomy Application" as TaxonomyApp
    component "Classification Worker" as Worker
    database "Main Database" as MainDb
  }

  UI --> API : read/write
  UI --> CacheDb : offline use
  API --> LedgerApp
  API --> TaxonomyApp
  API --> MobillsImport
  MobillsImport --> LedgerApp
  MobillsImport --> TaxonomyApp
  MobillsImport --> MainDb : row result + workflow state
  API --> MainDb : workflow state (category/tag status)
  Worker --> TaxonomyApp : retry category / apply tags
  Worker --> MainDb : update workflow state
  LedgerApp --> MainDb : ledger tables
  TaxonomyApp --> MainDb : taxonomy tables
}

User --> UI
MobillsFile --> MobillsImport : UTF-16 TSV

@enduml
