@startuml
skinparam componentStyle rectangle
skinparam shadowing false
hide stereotypes

actor User

package "Gonezo" {
  package "Client App" {
    component UI
    database "Local Storage" as CacheDb
  }

  package "Backend" {
    component "API / Workflows" as API
    component "Ledger Application" as LedgerApp
    component "Taxonomy Application" as TaxonomyApp
    component "Categorization Worker" as Worker
    database "Main Database" as MainDb
  }

  UI --> API : read/write
  UI --> CacheDb : offline use
  API --> LedgerApp
  API --> TaxonomyApp
  API --> MainDb : workflow state (pending/failed/assigned)
  Worker --> TaxonomyApp : retry assignment
  Worker --> MainDb : update workflow state
  LedgerApp --> MainDb : ledger tables
  TaxonomyApp --> MainDb : taxonomy tables
}

User --> UI

@enduml
