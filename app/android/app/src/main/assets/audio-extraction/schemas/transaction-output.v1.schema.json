{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["type"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["expense", "income", "transfer"]
    },
    "amount": {
      "type": "number"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "note": {
      "type": "string"
    },
    "transferToAccountId": {
      "type": "string"
    },
    "categoryName": {
      "type": "string"
    },
    "tagNames": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
